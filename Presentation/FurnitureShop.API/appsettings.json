{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "SqlServer": "Data Source=(localdb)\\MSSQLLocalDB;Initial Catalog=FurnitureShopDb;Integrated Security=True;Connect Timeout=30;Encrypt=False;"
  },
  "JWT": {
    "Issuer": "http://localhost:5147",
    "Audience": "http://localhost:5147",
    "Secret": ""
  },
  "Email": {
    "SmtpHost": "smtp.gmail.com",
    "SmtpPort": "587",
    "SenderName": "FurnitureShop",
    "SenderEmail": "",
    "Username": "",
    "Password": ""
  },

    "SeedAdmin": {
      "Email": "admin@furnitureshop.az",
      "Password": "Admin123!"
    },
  "Stripe": {
    "PublishableKey": "",
    "SecretKey": "",
    "WebhookSecret": ""
  },
  "FileUpload": {
    "UploadPath": "wwwroot/uploads",
    "BaseUrl": "/uploads"
  },
  "App": {
    "FrontendUrl": "http://localhost:5173"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/furnitureshop-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ]
  }
}